---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from './Container.astro';
import { withBase } from '../lib/url';

/**
 * Honest "not built yet" page for reserved routes. No fabricated data — just
 * states which phase the section lands in, so the live nav never 404s.
 */
interface Props {
  title: string;
  blurb: string;
  phase?: string;
}
const { title, blurb, phase = 'In progress' } = Astro.props;
---

<BaseLayout title={title}>
  <Container class="py-24 sm:py-32">
    <p class="text-sm font-semibold uppercase tracking-wide text-accent">{phase}</p>
    <h1 class="mt-3 text-3xl font-semibold text-ink sm:text-4xl">{title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">{blurb}</p>
    <p class="mt-10">
      <a href={withBase('/')} class="text-sm font-medium text-ink underline">&larr; Back home</a>
    </p>
  </Container>
</BaseLayout>
