---
import Container from './Container.astro';
import { withBase } from '../lib/url';

/**
 * Top nav. Every link points at a real route; pages may be stubs in early
 * phases but the information architecture is fixed here. Links go through
 * withBase() so they work under the Pages base path.
 */
const nav = [
  { label: 'Lessons', href: withBase('/lessons/') },
  { label: 'Portals', href: withBase('/portals/') },
  { label: 'Gurus', href: withBase('/gurus/') },
  { label: 'Deals', href: withBase('/deals/') },
  { label: 'Community', href: withBase('/community/') },
  { label: 'About', href: withBase('/about/') },
];

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
---

<header class="border-b border-rule bg-paper/85 backdrop-blur sticky top-0 z-20">
  <Container>
    <div class="flex h-16 items-center justify-between gap-6">
      <a
        href={withBase('/')}
        class="font-serif text-xl font-semibold tracking-tight text-ink no-underline"
      >
        Crowdfunding<span class="text-muted">Sucks</span>
      </a>
      <div class="flex items-center gap-5">
        <nav aria-label="Primary">
          <ul class="flex items-center gap-5">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                    class:list={[
                      'text-xs font-semibold uppercase tracking-wide no-underline transition-colors',
                      isActive(item.href)
                        ? 'text-ink'
                        : 'text-muted hover:text-ink',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        {/* account menu — revealed by the script when a session exists */}
        <div id="account-menu" class="relative hidden">
          <button
            id="account-trigger"
            type="button"
            aria-haspopup="menu"
            aria-expanded="false"
            class="flex items-center gap-2 rounded-full border border-rule py-1 pl-1 pr-3 transition-colors hover:bg-paper-raised"
          >
            <span
              id="account-initials"
              class="flex h-8 w-8 items-center justify-center rounded-full bg-accent text-xs font-semibold text-white"
            ></span>
            <span id="account-shortname" class="max-w-[8rem] truncate text-sm font-medium text-ink"></span>
            <span class="text-faint" aria-hidden="true">▾</span>
          </button>

          {/* dropdown */}
          <div
            id="account-dropdown"
            class="absolute right-0 mt-2 hidden w-60 overflow-hidden rounded-xl border border-rule bg-paper-raised shadow-lg"
            role="menu"
          >
            <div class="border-b border-rule px-4 py-3">
              <p id="account-name" class="truncate text-sm font-semibold text-ink"></p>
              <p id="account-email" class="truncate text-xs text-faint"></p>
            </div>

            {/* display name (username) — view + inline edit */}
            <div class="border-b border-rule px-4 py-3">
              <p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Display name</p>

              <div id="username-view" class="mt-1 flex items-center justify-between gap-2">
                <span id="username-value" class="truncate text-sm text-ink"></span>
                <button
                  id="username-edit"
                  type="button"
                  class="shrink-0 text-xs font-medium text-accent hover:underline"
                >
                  Edit
                </button>
              </div>

              <div id="username-form" class="mt-1 hidden">
                <input
                  id="username-input"
                  type="text"
                  maxlength="24"
                  class="w-full rounded-md border border-rule bg-paper px-2 py-1 text-sm text-ink focus:border-accent focus:outline-none"
                  placeholder="your_handle"
                />
                <div class="mt-1.5 flex items-center gap-2">
                  <button id="username-save" type="button" class="rounded-md bg-accent px-2.5 py-1 text-xs font-semibold text-white hover:opacity-90">Save</button>
                  <button id="username-cancel" type="button" class="text-xs text-muted hover:text-ink">Cancel</button>
                  <span id="username-note" class="text-[0.65rem] text-faint"></span>
                </div>
              </div>
            </div>

            {/* updates preference — cycles Off / Newsletter / Newsletter + emails */}
            <div class="border-b border-rule px-4 py-3">
              <p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Updates</p>
              <button
                id="updates-toggle"
                type="button"
                class="mt-1.5 inline-flex items-center gap-2 rounded-full border border-rule px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-accent/50"
                aria-label="Cycle update preferences"
                title="Click to cycle: off → newsletter → newsletter + emails"
              >
                <span id="updates-checks" class="inline-flex min-w-[1.4rem] justify-center font-semibold text-[var(--color-gain)]"></span>
                <span id="updates-label"></span>
              </button>
            </div>

            <button
              id="account-signout"
              type="button"
              role="menuitem"
              class="w-full px-4 py-2.5 text-left text-sm text-muted transition-colors hover:bg-paper hover:text-ink"
            >
              Sign out
            </button>
          </div>
        </div>
      </div>
    </div>
  </Container>
</header>

<script>
  import { supabase, userInitials, userName } from '../lib/supabase';
  import { resolveUsername, setUsername } from '../lib/comments';
  import { withBase } from '../lib/url';

  const menu = document.getElementById('account-menu');
  const trigger = document.getElementById('account-trigger');
  const dropdown = document.getElementById('account-dropdown');
  const initialsEl = document.getElementById('account-initials');
  const shortnameEl = document.getElementById('account-shortname');
  const nameEl = document.getElementById('account-name');
  const emailEl = document.getElementById('account-email');
  const signoutBtn = document.getElementById('account-signout');

  // username view/edit
  const unView = document.getElementById('username-view');
  const unValue = document.getElementById('username-value');
  const unEditBtn = document.getElementById('username-edit');
  const unForm = document.getElementById('username-form');
  const unInput = document.getElementById('username-input') as HTMLInputElement | null;
  const unSave = document.getElementById('username-save');
  const unCancel = document.getElementById('username-cancel');
  const unNote = document.getElementById('username-note');

  // updates preference (0 = off, 1 = newsletter, 2 = newsletter + emails)
  const updBtn = document.getElementById('updates-toggle');
  const updChecks = document.getElementById('updates-checks');
  const updLabel = document.getElementById('updates-label');
  let updLevel = 0;
  let updBusy = false;

  type U = Parameters<typeof userInitials>[0];
  let currentUsername = '';

  function showUsernameView() {
    unForm?.classList.add('hidden');
    unView?.classList.remove('hidden');
    if (unNote) unNote.textContent = '';
  }
  function showUsernameForm() {
    if (unInput) unInput.value = currentUsername;
    unView?.classList.add('hidden');
    unForm?.classList.remove('hidden');
    unInput?.focus();
  }

  function render(user: U) {
    if (!menu) return;
    if (user) {
      const name = userName(user);
      const first = name.split(/\s+/)[0] || name;
      if (initialsEl) initialsEl.textContent = userInitials(user);
      if (shortnameEl) shortnameEl.textContent = first;
      if (nameEl) nameEl.textContent = name;
      if (emailEl) emailEl.textContent = user.email ?? '';
      currentUsername = resolveUsername(user);
      if (unValue) unValue.textContent = currentUsername;
      showUsernameView();

      const m = user.user_metadata ?? {};
      updLevel = m.emails_opt_in ? 2 : m.newsletter_opt_in ? 1 : 0;
      paintUpdates();

      menu.classList.remove('hidden');
    } else {
      menu.classList.add('hidden');
      closeDropdown();
    }
  }

  function openDropdown() {
    dropdown?.classList.remove('hidden');
    trigger?.setAttribute('aria-expanded', 'true');
  }
  function closeDropdown() {
    dropdown?.classList.add('hidden');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.contains('hidden') ? openDropdown() : closeDropdown();
  });
  document.addEventListener('click', (e) => {
    if (menu && !menu.contains(e.target as Node)) closeDropdown();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });

  supabase.auth.getUser().then(({ data }) => render(data.user));
  supabase.auth.onAuthStateChange((_e, session) => render(session?.user ?? null));

  signoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(withBase('/'));
  });

  // --- username editing ---
  unEditBtn?.addEventListener('click', showUsernameForm);
  unCancel?.addEventListener('click', showUsernameView);

  async function saveUsername() {
    const next = (unInput?.value ?? '').trim();
    if (!next) {
      if (unNote) unNote.textContent = 'Enter a name.';
      return;
    }
    if (unSave) (unSave as HTMLButtonElement).disabled = true;
    if (unNote) unNote.textContent = 'Saving…';
    const { error } = await setUsername(next);
    if (unSave) (unSave as HTMLButtonElement).disabled = false;
    if (error) {
      if (unNote) unNote.textContent = 'Could not save.';
      return;
    }
    currentUsername = next.slice(0, 24).replace(/\s+/g, '_');
    if (unValue) unValue.textContent = currentUsername;
    showUsernameView();
  }

  unSave?.addEventListener('click', saveUsername);
  unInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      saveUsername();
    } else if (e.key === 'Escape') {
      e.preventDefault();
      e.stopPropagation(); // cancel the edit without also closing the dropdown
      showUsernameView();
    }
  });

  // --- updates preference (Off / Newsletter / Newsletter + emails) ---
  const UPD_LABELS = ['Off', 'Newsletter', 'Newsletter + emails'];
  function paintUpdates() {
    if (updChecks) updChecks.textContent = '✓'.repeat(updLevel);
    if (updLabel) updLabel.textContent = UPD_LABELS[updLevel];
    updBtn?.setAttribute('aria-label', `Updates: ${UPD_LABELS[updLevel]} (click to change)`);
  }

  updBtn?.addEventListener('click', async () => {
    if (updBusy) return;
    updBusy = true;
    const prev = updLevel;
    updLevel = (updLevel + 1) % 3; // 0 -> 1 -> 2 -> 0
    paintUpdates(); // optimistic
    const { error } = await supabase.auth.updateUser({
      data: {
        newsletter_opt_in: updLevel >= 1,
        emails_opt_in: updLevel >= 2,
      },
    });
    updBusy = false;
    if (error) {
      updLevel = prev; // revert
      paintUpdates();
    }
  });
</script>
