---
import Container from './Container.astro';
import { withBase } from '../lib/url';

/**
 * Top nav. Every link points at a real route; pages may be stubs in early
 * phases but the information architecture is fixed here. Links go through
 * withBase() so they work under the Pages base path.
 */
const nav = [
  { label: 'Lessons', href: withBase('/lessons/') },
  { label: 'Portals', href: withBase('/portals/') },
  { label: 'Gurus', href: withBase('/gurus/') },
  { label: 'Deals', href: withBase('/deals/') },
  { label: 'Community', href: withBase('/community/') },
  { label: 'About', href: withBase('/about/') },
];

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
---

<header class="border-b border-rule bg-paper/85 backdrop-blur sticky top-0 z-20">
  <Container>
    <div class="flex h-16 items-center justify-between gap-6">
      <a
        href={withBase('/')}
        class="font-serif text-xl font-semibold tracking-tight text-ink no-underline"
      >
        Crowdfunding<span class="text-muted">Sucks</span>
      </a>
      <div class="flex items-center gap-5">
        <nav aria-label="Primary">
          <ul class="flex items-center gap-5">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                    class:list={[
                      'text-xs font-semibold uppercase tracking-wide no-underline transition-colors',
                      isActive(item.href)
                        ? 'text-ink'
                        : 'text-muted hover:text-ink',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        {/* account menu — revealed by the script when a session exists */}
        <div id="account-menu" class="relative hidden">
          <button
            id="account-trigger"
            type="button"
            aria-haspopup="menu"
            aria-expanded="false"
            class="flex items-center gap-2 rounded-full border border-rule py-1 pl-1 pr-3 transition-colors hover:bg-paper-raised"
          >
            <span
              id="account-initials"
              class="flex h-8 w-8 items-center justify-center rounded-full bg-accent text-xs font-semibold text-white"
            ></span>
            <span id="account-shortname" class="max-w-[8rem] truncate text-sm font-medium text-ink"></span>
            <span class="text-faint" aria-hidden="true">▾</span>
          </button>

          {/* dropdown */}
          <div
            id="account-dropdown"
            class="absolute right-0 mt-2 hidden w-60 overflow-hidden rounded-xl border border-rule bg-paper-raised shadow-lg"
            role="menu"
          >
            <div class="border-b border-rule px-4 py-3">
              <p id="account-name" class="truncate text-sm font-semibold text-ink"></p>
              <p id="account-email" class="truncate text-xs text-faint"></p>
            </div>
            <button
              id="account-signout"
              type="button"
              role="menuitem"
              class="w-full px-4 py-2.5 text-left text-sm text-muted transition-colors hover:bg-paper hover:text-ink"
            >
              Sign out
            </button>
          </div>
        </div>
      </div>
    </div>
  </Container>
</header>

<script>
  import { supabase, userInitials, userName } from '../lib/supabase';
  import { withBase } from '../lib/url';

  const menu = document.getElementById('account-menu');
  const trigger = document.getElementById('account-trigger');
  const dropdown = document.getElementById('account-dropdown');
  const initialsEl = document.getElementById('account-initials');
  const shortnameEl = document.getElementById('account-shortname');
  const nameEl = document.getElementById('account-name');
  const emailEl = document.getElementById('account-email');
  const signoutBtn = document.getElementById('account-signout');

  type U = Parameters<typeof userInitials>[0];

  function render(user: U) {
    if (!menu) return;
    if (user) {
      const name = userName(user);
      const first = name.split(/\s+/)[0] || name;
      if (initialsEl) initialsEl.textContent = userInitials(user);
      if (shortnameEl) shortnameEl.textContent = first;
      if (nameEl) nameEl.textContent = name;
      if (emailEl) emailEl.textContent = user.email ?? '';
      menu.classList.remove('hidden');
    } else {
      menu.classList.add('hidden');
      closeDropdown();
    }
  }

  function openDropdown() {
    dropdown?.classList.remove('hidden');
    trigger?.setAttribute('aria-expanded', 'true');
  }
  function closeDropdown() {
    dropdown?.classList.add('hidden');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.contains('hidden') ? openDropdown() : closeDropdown();
  });
  document.addEventListener('click', (e) => {
    if (menu && !menu.contains(e.target as Node)) closeDropdown();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });

  supabase.auth.getUser().then(({ data }) => render(data.user));
  supabase.auth.onAuthStateChange((_e, session) => render(session?.user ?? null));

  signoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(withBase('/'));
  });
</script>
