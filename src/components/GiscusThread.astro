---
import { giscusEnabled } from '../lib/giscus';

/**
 * A single Giscus (GitHub Discussions) thread, keyed by `term`. Per CLAUDE.md,
 * ALL discussion is Giscus — never a custom comment backend.
 *
 * Two variants:
 *  - variant="open"   → the iframe mounts on load (use sparingly; 1 per page).
 *  - variant="toggle" → renders a "💬 Discuss" button; the iframe is injected
 *                       only when the user opens it (lazy — lets one page hold
 *                       many per-deal threads without N iframes at once).
 *
 * Mounting is handled by a shared controller (GiscusController.astro) so this
 * component stays markup-only and the client logic is defined once per page.
 */
interface Props {
  term: string;
  variant?: 'open' | 'toggle';
  label?: string; // toggle button label
}
const { term, variant = 'open', label = 'Discuss' } = Astro.props;
---

{
  giscusEnabled ? (
    <div class="giscus-thread" data-term={term} data-variant={variant}>
      {variant === 'toggle' && (
        <button
          type="button"
          class="giscus-toggle inline-flex items-center gap-1.5 rounded-full border border-rule px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-accent/50 hover:bg-accent/5 hover:text-accent"
          aria-expanded="false"
        >
          <span aria-hidden="true">💬</span>
          <span class="giscus-toggle-label">{label}</span>
        </button>
      )}
      {/* the iframe is injected here on demand by the controller */}
      <div class="giscus-mount mt-3" hidden={variant === 'toggle'} />
    </div>
  ) : (
    <div class="rounded-md border border-dashed border-rule bg-paper-raised p-4 text-sm text-muted">
      <p class="font-medium text-ink">Discussion (Giscus / GitHub Discussions) is not configured.</p>
      <p class="mt-1 text-xs text-faint">Thread key: <code class="font-mono">{term}</code></p>
    </div>
  )
}
