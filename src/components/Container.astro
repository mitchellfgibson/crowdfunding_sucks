---
/**
 * Layout width primitive. `width="prose"` constrains to the reading measure for
 * long-form; default is the wider site column.
 */
interface Props {
  width?: 'site' | 'prose';
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { width = 'site', as = 'div', class: className = '' }: Props = Astro.props;
const Tag = as;
// `prose` stays at the reading measure for long-form legibility; `site` uses a
// wider column so pages aren't boxed into the middle on large screens.
const max = width === 'prose' ? 'max-w-[var(--spacing-measure)]' : 'max-w-7xl';
---

<Tag class:list={['mx-auto w-full px-5 sm:px-8 lg:px-12', max, className]}>
  <slot />
</Tag>
