---
import { monogram, avatarColor } from '../lib/handle';

/** Deterministic monogram avatar for an outlet "account". */
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 40, class: className = '' } = Astro.props;
const bg = avatarColor(name);
---

<span
  class:list={['inline-flex items-center justify-center rounded-md font-semibold text-white', className]}
  style={`background:${bg}; width:${size}px; height:${size}px; font-size:${Math.round(size * 0.4)}px`}
  aria-hidden="true"
>
  {monogram(name)}
</span>
