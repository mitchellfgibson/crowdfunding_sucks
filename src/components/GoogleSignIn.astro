---
/**
 * "Join with Google" button — real Supabase Google OAuth. Clicking it starts
 * the Google sign-in redirect via signInWithGoogle() (src/lib/supabase.ts) and
 * returns to /auth/callback/. Requires the Google provider to be enabled in the
 * Supabase project (one-time dashboard step) — until then Google returns an
 * error which we surface in the note.
 */
interface Props {
  label?: string;
}
const { label = 'Join with Google' } = Astro.props;
---

<div class="google-signin flex flex-col items-center">
  <button
    type="button"
    class="google-signin-btn inline-flex items-center gap-3 rounded-full border border-rule bg-white px-6 py-3 text-base font-medium text-[#3c4043] shadow-sm transition-shadow hover:shadow-md focus:outline-none focus:ring-2 focus:ring-accent/40"
  >
    <svg width="20" height="20" viewBox="0 0 18 18" aria-hidden="true">
      <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92c1.7-1.57 2.68-3.88 2.68-6.62z"/>
      <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.03-3.7H.96v2.33A9 9 0 0 0 9 18z"/>
      <path fill="#FBBC05" d="M3.97 10.72a5.4 5.4 0 0 1 0-3.44V4.95H.96a9 9 0 0 0 0 8.1l3.01-2.33z"/>
      <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58A9 9 0 0 0 .96 4.95l3.01 2.33C4.68 5.16 6.66 3.58 9 3.58z"/>
    </svg>
    {label}
  </button>
  <p class="google-signin-note mt-2 text-xs text-faint">No credit card.</p>
</div>

<script>
  import { signInWithGoogle } from '../lib/supabase';

  // Bind every instance (the button can appear more than once per page).
  document.querySelectorAll<HTMLElement>('.google-signin').forEach((root) => {
    const btn = root.querySelector<HTMLButtonElement>('.google-signin-btn');
    const note = root.querySelector('.google-signin-note');
    btn?.addEventListener('click', async () => {
      btn.disabled = true;
      if (note) note.textContent = 'Redirecting to Google…';
      const { error } = await signInWithGoogle();
      if (error) {
        btn.disabled = false;
        if (note)
          note.textContent =
            'Google sign-in isn’t enabled yet (enable the Google provider in Supabase).';
      }
      // on success the browser redirects to Google, then back to /auth/callback/
    });
  });
</script>
