---
import { monogram, avatarColor } from '../lib/handle';
import { withBase } from '../lib/url';

/**
 * A platform's logo. Priority:
 *   1. an explicit local `logo` file under /public/logos/ (for sites whose
 *      favicon service has no usable icon), then
 *   2. the domain favicon loaded at runtime (nominative use; not stored), then
 *   3. a colored letter-monogram fallback (shown underneath; revealed if the
 *      <img> errors out).
 */
interface Props {
  name: string;
  url: string;
  logo?: string; // filename in /public/logos/, e.g. "startengine.png"
  size?: number;
  class?: string;
}
const { name, url, logo, size = 40, class: className = '' } = Astro.props;

let host = '';
try {
  host = new URL(url).host.replace(/^www\./, '');
} catch {
  host = '';
}
// Local file wins; otherwise the DuckDuckGo icon service.
const src = logo
  ? withBase(`/logos/${logo}`)
  : host
    ? `https://icons.duckduckgo.com/ip3/${host}.ico`
    : '';
const bg = avatarColor(name);
---

<span
  class:list={['relative inline-flex shrink-0 items-center justify-center overflow-hidden rounded-md', className]}
  style={`width:${size}px;height:${size}px;background:${bg}`}
>
  <span class="font-semibold text-white" style={`font-size:${Math.round(size * 0.4)}px`} aria-hidden="true">
    {monogram(name)}
  </span>
  {
    src && (
      <img
        src={src}
        alt={`${name} logo`}
        width={size}
        height={size}
        loading="lazy"
        class="absolute inset-0 h-full w-full bg-white object-contain p-1"
        onerror="this.remove()"
      />
    )
  }
</span>
