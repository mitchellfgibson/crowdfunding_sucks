---
import Avatar from './Avatar.astro';
import { sampleChat, type ChatMessage } from '../lib/sampleChat';

/**
 * Community chat log. Renders the deterministic FICTIONAL sample conversation
 * server-side (kept as seed content + clearly labeled), then a script hydrates
 * REAL comments from Supabase below them and enables the composer for signed-in
 * users. The `seed` doubles as the Supabase thread key.
 *
 * Lives strictly in the "community discussion — not editorial" zone.
 * Collapsible via native <details>.
 */
interface Props {
  seed: string; // stable key -> stable conversation
  messages?: ChatMessage[]; // pre-built thread (overrides deal context)
  ticker?: string;
  outcome?: string;
  ratio?: number | null;
  label?: string;
  open?: boolean;
}
const { seed, messages: provided, ticker, outcome, ratio = null, label = 'Discuss', open = false } =
  Astro.props;
const messages =
  provided ?? sampleChat(seed, { ticker: ticker ?? 'this', outcome: outcome ?? 'unknown', ratio });
---

<details class="chatlog group" data-thread={seed} open={open}>
  <summary
    class="inline-flex cursor-pointer list-none items-center gap-1.5 rounded-full border border-rule px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-accent/50 hover:bg-accent/5 hover:text-accent [&::-webkit-details-marker]:hidden"
  >
    <span aria-hidden="true">💬</span>
    <span>{label}</span>
    <span class="text-faint">· <span class="chat-count">{messages.length}</span></span>
    <span class="text-faint transition-transform group-open:rotate-90" aria-hidden="true">›</span>
  </summary>

  <div class="mt-3 rounded-lg border border-rule bg-paper">
    <div class="flex items-center justify-between border-b border-rule px-3 py-1.5">
      <span class="text-[0.65rem] font-semibold uppercase tracking-wide text-faint">
        Community chat
      </span>
      <span
        class="rounded-full border border-[var(--color-notice)]/50 px-1.5 py-0.5 text-[0.6rem] font-medium text-[var(--color-notice)]"
        title="Includes fictional sample comments to seed the conversation"
      >
        includes samples
      </span>
    </div>

    {/* seed (sample) messages — rendered server-side */}
    <ul class="chat-list divide-y divide-rule">
      {
        messages.map((m) => (
          <li class="flex gap-2.5 px-3 py-2.5">
            <Avatar name={m.author} size={28} class="mt-0.5 shrink-0" />
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline gap-2">
                <span class="truncate text-sm font-medium text-ink">{m.author}</span>
                <span class="text-[0.65rem] text-faint">{m.ago}</span>
                <span class="rounded bg-rule px-1 text-[0.55rem] uppercase tracking-wide text-faint">sample</span>
              </div>
              <p class="text-sm leading-relaxed text-muted">{m.body}</p>
              {m.reactions && (
                <div class="mt-1 flex gap-1">
                  {m.reactions.map((r) => (
                    <span class="inline-flex items-center gap-1 rounded-full border border-rule bg-paper-raised px-1.5 py-0.5 text-[0.65rem] text-muted">
                      <span>{r.emoji}</span>
                      <span class="tabular-nums">{r.n}</span>
                    </span>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))
      }
      {/* live comments get appended here by the script */}
    </ul>

    {/* composer — enabled for signed-in users, sign-in prompt otherwise */}
    <div class="chat-composer border-t border-rule px-3 py-2">
      <div class="chat-as hidden items-center gap-1.5 pb-1.5 text-[0.65rem] text-faint">
        <span>commenting as</span>
        <button type="button" class="chat-username font-semibold text-ink hover:text-accent" title="Click to change your display name"></button>
      </div>
      <div class="flex items-center gap-2">
        <input
          type="text"
          class="chat-input flex-1 rounded-full border border-rule bg-paper-raised px-3 py-1.5 text-sm text-ink placeholder:text-faint"
          placeholder="Sign in to join the conversation"
          maxlength="800"
          disabled
        />
        <button type="button" class="chat-send rounded-full bg-accent px-3 py-1.5 text-xs font-semibold text-white disabled:opacity-50" disabled>
          Send
        </button>
      </div>
      <p class="chat-note mt-1 text-[0.65rem] text-faint"></p>
    </div>
  </div>
</details>

<script>
  import { supabase } from '../lib/supabase';
  import {
    fetchComments, postComment, resolveUsername, setUsername, timeAgo,
    fetchReactions, toggleReaction, REACTION_EMOJIS, type Comment,
  } from '../lib/comments';

  function esc(s: string) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }
  function initials(name: string) {
    return (name.replace(/[^a-z0-9]/gi, '').slice(0, 2) || '?').toUpperCase();
  }

  document.querySelectorAll<HTMLDetailsElement>('.chatlog').forEach((root) => {
    const thread = root.dataset.thread!;
    const list = root.querySelector<HTMLElement>('.chat-list')!;
    const countEl = root.querySelector<HTMLElement>('.chat-count')!;
    const asRow = root.querySelector<HTMLElement>('.chat-as')!;
    const unameBtn = root.querySelector<HTMLButtonElement>('.chat-username')!;
    const input = root.querySelector<HTMLInputElement>('.chat-input')!;
    const send = root.querySelector<HTMLButtonElement>('.chat-send')!;
    const note = root.querySelector<HTMLElement>('.chat-note')!;

    let username = '';
    let signedIn = false;
    let loaded = false;
    const sampleCount = list.querySelectorAll('li').length;

    // ---- one comment node (top-level or reply) -------------------------
    function commentNode(c: Comment, isReply: boolean): HTMLLIElement {
      const li = document.createElement('li');
      li.className = isReply ? 'flex gap-2 py-2' : 'flex gap-2.5 px-3 py-2.5';
      li.dataset.id = c.id;
      const avatar = isReply ? 'h-6 w-6 text-[0.55rem]' : 'h-7 w-7 text-[0.6rem]';
      li.innerHTML = `
        <span class="mt-0.5 flex ${avatar} shrink-0 items-center justify-center rounded-md bg-accent font-semibold text-white">${initials(c.username)}</span>
        <div class="min-w-0 flex-1">
          <div class="flex items-baseline gap-2">
            <span class="truncate text-sm font-medium text-ink">${esc(c.username)}</span>
            <span class="text-[0.65rem] text-faint">${timeAgo(c.created_at)}</span>
          </div>
          <p class="text-sm leading-relaxed text-ink">${esc(c.body)}</p>
          <div class="rx-bar mt-1.5 flex flex-wrap items-center gap-1" data-comment="${c.id}"></div>
          <div class="chat-actions mt-1 flex items-center gap-3 text-[0.65rem] text-faint">
            <button type="button" class="react-add inline-flex items-center gap-1 rounded-full border border-rule px-1.5 py-0.5 text-faint transition-colors hover:border-accent/50 hover:bg-accent/5 hover:text-accent" aria-label="Add reaction" title="Add reaction">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="8.5" cy="9.5" r="1.1" fill="currentColor"/>
                <circle cx="13.5" cy="9.5" r="1.1" fill="currentColor"/>
                <path d="M8 13.5c.9 1.1 2 1.6 3 1.6s2.1-.5 3-1.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M19 3.5v5M16.5 6h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </button>
            ${isReply ? '' : '<button type="button" class="reply-btn hover:text-accent">↳ reply</button>'}
          </div>
          ${isReply ? '' : '<ul class="reply-list mt-2 space-y-1 border-l border-rule pl-3"></ul><div class="reply-box mt-2 hidden"></div>'}
        </div>`;
      wireComment(li, c.id);
      return li;
    }

    // ---- Slack-style reactions ----------------------------------------
    function renderReactionBar(bar: HTMLElement, summary?: { counts: Record<string, number>; mine: Set<string> }) {
      const counts = summary?.counts ?? {};
      const mine = summary?.mine ?? new Set<string>();
      const pills = Object.entries(counts)
        .filter(([, n]) => n > 0)
        .map(([emoji, n]) => {
          const on = mine.has(emoji);
          return `<button type="button" class="rx-pill inline-flex items-center gap-1 rounded-full border px-1.5 py-0.5 text-[0.65rem] transition-colors ${
            on ? 'border-accent bg-accent/10 text-accent' : 'border-rule text-muted hover:border-accent/50'
          }" data-emoji="${emoji}"><span>${emoji}</span><span class="tabular-nums">${n}</span></button>`;
        })
        .join('');
      // the "add reaction" button is rendered in chat-actions; here we keep pills
      bar.innerHTML = pills;
      bar.querySelectorAll<HTMLButtonElement>('.rx-pill').forEach((pill) => {
        pill.addEventListener('click', () => react(bar.dataset.comment!, pill.dataset.emoji!, bar));
      });
    }

    async function react(commentId: string, emoji: string, bar: HTMLElement) {
      if (!signedIn) { note.textContent = 'Sign in to react.'; return; }
      const res = await toggleReaction(commentId, emoji);
      if (!res.ok) { note.textContent = res.message; return; }
      // re-fetch just this comment's reactions to repaint accurately
      const summaries = await fetchReactions([commentId]);
      renderReactionBar(bar, summaries.get(commentId));
    }

    // emoji picker popover
    let openPicker: HTMLElement | null = null;
    function closePicker() { openPicker?.remove(); openPicker = null; }
    document.addEventListener('click', (e) => {
      if (openPicker && !openPicker.contains(e.target as Node)) closePicker();
    });

    function showPicker(anchor: HTMLElement, commentId: string, bar: HTMLElement) {
      closePicker();
      if (!signedIn) { note.textContent = 'Sign in to react.'; return; }
      const pop = document.createElement('div');
      pop.className = 'absolute z-30 mt-1 flex gap-1 rounded-full border border-rule bg-paper-raised px-2 py-1 shadow-lg';
      pop.innerHTML = REACTION_EMOJIS.map(
        (e) => `<button type="button" class="px-1 text-base hover:scale-125 transition-transform" data-emoji="${e}">${e}</button>`,
      ).join('');
      anchor.style.position = 'relative';
      anchor.appendChild(pop);
      openPicker = pop;
      pop.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
        b.addEventListener('click', (ev) => {
          ev.stopPropagation();
          react(commentId, b.dataset.emoji!, bar);
          closePicker();
        });
      });
    }

    // ---- wire per-comment actions (react, reply) ----------------------
    function wireComment(li: HTMLElement, commentId: string) {
      const addBtn = li.querySelector<HTMLButtonElement>('.react-add')!;
      const bar = li.querySelector<HTMLElement>('.rx-bar')!;
      addBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        showPicker(addBtn, commentId, bar);
      });

      const replyBtn = li.querySelector<HTMLButtonElement>('.reply-btn');
      if (replyBtn) {
        const box = li.querySelector<HTMLElement>('.reply-box')!;
        replyBtn.addEventListener('click', () => {
          if (!signedIn) { note.textContent = 'Sign in to reply.'; return; }
          if (!box.dataset.built) {
            box.innerHTML = `
              <div class="flex items-center gap-2">
                <input type="text" maxlength="800" placeholder="Reply…" class="reply-input flex-1 rounded-full border border-rule bg-paper-raised px-3 py-1 text-sm text-ink placeholder:text-faint" />
                <button type="button" class="reply-send rounded-full bg-accent px-2.5 py-1 text-[0.65rem] font-semibold text-white">Reply</button>
              </div>`;
            box.dataset.built = '1';
            const ri = box.querySelector<HTMLInputElement>('.reply-input')!;
            const rs = box.querySelector<HTMLButtonElement>('.reply-send')!;
            const doReply = async () => {
              const body = ri.value;
              if (!body.trim()) return;
              rs.disabled = true;
              const res = await postComment(thread, body, username, commentId);
              rs.disabled = false;
              if (!res.ok) { note.textContent = res.message; return; }
              const rlist = li.querySelector<HTMLElement>('.reply-list')!;
              rlist.appendChild(commentNode(res.comment, true));
              ri.value = '';
              box.classList.add('hidden');
              bumpCount();
            };
            rs.addEventListener('click', doReply);
            ri.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') { ev.preventDefault(); doReply(); } });
          }
          box.classList.toggle('hidden');
          box.querySelector<HTMLInputElement>('.reply-input')?.focus();
        });
      }
    }

    function bumpCount() {
      countEl.textContent = String(sampleCount + list.querySelectorAll('li[data-id], .reply-list li').length);
    }

    // ---- load + nest ---------------------------------------------------
    async function loadOnce() {
      if (loaded) return;
      loaded = true;
      const comments = await fetchComments(thread);
      const tops = comments.filter((c) => !c.parent_id);
      const repliesBy = new Map<string, Comment[]>();
      comments.filter((c) => c.parent_id).forEach((c) => {
        const arr = repliesBy.get(c.parent_id!) ?? [];
        arr.push(c);
        repliesBy.set(c.parent_id!, arr);
      });

      tops.forEach((c) => {
        const li = commentNode(c, false);
        list.appendChild(li);
        const rlist = li.querySelector<HTMLElement>('.reply-list')!;
        (repliesBy.get(c.id) ?? []).forEach((r) => rlist.appendChild(commentNode(r, true)));
      });
      bumpCount();

      // hydrate all reaction bars in one query
      const summaries = await fetchReactions(comments.map((c) => c.id));
      root.querySelectorAll<HTMLElement>('.rx-bar').forEach((bar) => {
        const id = bar.dataset.comment!;
        if (summaries.has(id)) renderReactionBar(bar, summaries.get(id));
      });
    }

    if (root.open) loadOnce();
    root.addEventListener('toggle', () => root.open && loadOnce());

    // ---- session / composer -------------------------------------------
    async function applyAuth(user: any) {
      signedIn = !!user;
      if (user) {
        username = resolveUsername(user);
        asRow.classList.remove('hidden');
        asRow.classList.add('flex');
        unameBtn.textContent = username;
        input.disabled = false;
        send.disabled = false;
        input.placeholder = 'Add a comment…';
      } else {
        asRow.classList.add('hidden');
        input.disabled = true;
        send.disabled = true;
        input.placeholder = 'Sign in to join the conversation';
      }
    }
    supabase.auth.getUser().then(({ data }) => applyAuth(data.user));
    supabase.auth.onAuthStateChange((_e, s) => applyAuth(s?.user ?? null));

    unameBtn.addEventListener('click', async () => {
      const next = prompt('Choose a display name:', username);
      if (!next || !next.trim()) return;
      const { error } = await setUsername(next);
      if (!error) {
        username = next.trim().slice(0, 24).replace(/\s+/g, '_');
        unameBtn.textContent = username;
      }
    });

    async function submit() {
      const body = input.value;
      if (!body.trim()) return;
      send.disabled = true;
      note.textContent = 'Posting…';
      const res = await postComment(thread, body, username);
      send.disabled = false;
      if (!res.ok) { note.textContent = res.message; return; }
      list.appendChild(commentNode(res.comment, false));
      bumpCount();
      input.value = '';
      note.textContent = '';
    }
    send.addEventListener('click', submit);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submit(); }
    });
  });
</script>
