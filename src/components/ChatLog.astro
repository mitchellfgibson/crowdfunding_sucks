---
import Avatar from './Avatar.astro';
import { sampleChat } from '../lib/sampleChat';

/**
 * Illustrative sample chat log for a deal/profile. Renders a deterministic,
 * FICTIONAL conversation so the community interface can be previewed without
 * GitHub accounts or a real backend. Clearly labeled as sample; the composer is
 * disabled. Lives strictly in the "community discussion — not editorial" zone.
 *
 * Collapsible via native <details> (no JS): a "💬 Discuss" summary toggles the
 * thread, so a profile page can hold many per-deal chats cheaply.
 */
interface Props {
  seed: string; // stable key -> stable conversation
  ticker: string;
  outcome: string;
  ratio: number | null;
  label?: string;
  open?: boolean;
}
const { seed, ticker, outcome, ratio, label = 'Discuss', open = false } = Astro.props;
const messages = sampleChat(seed, { ticker, outcome, ratio });
---

<details class="group" open={open}>
  <summary
    class="inline-flex cursor-pointer list-none items-center gap-1.5 rounded-full border border-rule px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-accent/50 hover:bg-accent/5 hover:text-accent [&::-webkit-details-marker]:hidden"
  >
    <span aria-hidden="true">💬</span>
    <span>{label}</span>
    <span class="text-faint">· {messages.length}</span>
    <span class="text-faint transition-transform group-open:rotate-90" aria-hidden="true">›</span>
  </summary>

  <div class="mt-3 rounded-lg border border-rule bg-paper">
    <div class="flex items-center justify-between border-b border-rule px-3 py-1.5">
      <span class="text-[0.65rem] font-semibold uppercase tracking-wide text-faint">
        Community chat
      </span>
      <span
        class="rounded-full border border-[var(--color-notice)]/50 px-1.5 py-0.5 text-[0.6rem] font-medium text-[var(--color-notice)]"
        title="Fictional sample conversation — not real users"
      >
        illustrative sample
      </span>
    </div>

    <ul class="divide-y divide-rule">
      {
        messages.map((m) => (
          <li class="flex gap-2.5 px-3 py-2.5">
            <Avatar name={m.author} size={28} class="mt-0.5 shrink-0" />
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline gap-2">
                <span class="truncate text-sm font-medium text-ink">{m.author}</span>
                <span class="text-[0.65rem] text-faint">{m.ago}</span>
              </div>
              <p class="text-sm leading-relaxed text-muted">{m.body}</p>
              {m.reactions && (
                <div class="mt-1 flex gap-1">
                  {m.reactions.map((r) => (
                    <span class="inline-flex items-center gap-1 rounded-full border border-rule bg-paper-raised px-1.5 py-0.5 text-[0.65rem] text-muted">
                      <span>{r.emoji}</span>
                      <span class="tabular-nums">{r.n}</span>
                    </span>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))
      }
    </ul>

    {/* disabled composer — preview only */}
    <div class="flex items-center gap-2 border-t border-rule px-3 py-2">
      <input
        type="text"
        disabled
        placeholder="Sign-in & live chat coming soon — sample preview"
        class="flex-1 rounded-full border border-rule bg-paper-raised px-3 py-1.5 text-sm text-faint placeholder:text-faint"
      />
      <button
        type="button"
        disabled
        class="rounded-full bg-rule px-3 py-1.5 text-xs font-medium text-faint"
      >
        Send
      </button>
    </div>
  </div>
</details>
