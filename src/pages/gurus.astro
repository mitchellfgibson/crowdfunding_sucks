---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Avatar from '../components/Avatar.astro';
import PortalLogo from '../components/PortalLogo.astro';
import { withBase } from '../lib/url';
import { publishers, publisherSlug, PUBLISHERS_INTRO, PUBLISHERS_SOURCE } from '../data/publishers';

/**
 * Publisher / analyst directory, sourced from crowdfundingsucks.com/gurus.
 * FACTS ONLY — name, publisher, focus area, with a citation. No track-record
 * numbers, no scoring, no opinion (BUILD_PLAN §6.3: named individuals are
 * reference-only until a sourced-recommendation methodology exists).
 */
const totalAnalysts = publishers.reduce((n, p) => n + p.analysts.length, 0);
---

<BaseLayout
  title="Publishers & Gurus"
  description="A sourced directory of financial publishers promoting startup, Reg CF, and Reg A deals, and the analysts writing under each."
>
  <Container class="py-10">
    <header class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent">Directory</p>
      <h1 class="mt-2 text-3xl font-semibold text-ink sm:text-4xl">Publishers &amp; Gurus</h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">{PUBLISHERS_INTRO}</p>
      <p class="mt-3 text-sm text-faint">
        {publishers.length} publishers · {totalAnalysts} analysts tracked.
      </p>
    </header>

    {/* reference-only notice — no performance claims */}
    <div
      role="note"
      class="mt-6 rounded-md border border-[var(--color-notice)]/40 bg-[var(--color-notice)]/10 px-4 py-3 text-sm leading-relaxed text-[var(--color-notice)]"
    >
      <strong>Reference directory only.</strong> This lists who publishes and what
      they cover. No track records, returns, or performance ratings are shown —
      those appear only when individual recommendations can be matched to
      publicly verifiable outcomes, with sources.
    </div>

    <div class="mt-8 space-y-4">
      {
        publishers.map((pub) => (
          <a
            href={withBase(`/gurus/${publisherSlug(pub.name)}/`)}
            class="group block rounded-xl border border-rule bg-paper-raised p-5 no-underline shadow-sm transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:bg-accent/5 hover:shadow-md"
          >
            <div class="flex items-start gap-3">
              <PortalLogo name={pub.name} url={pub.url} size={44} />
              <div class="min-w-0">
                <h2 class="font-serif text-xl text-ink group-hover:text-accent">{pub.name}</h2>
                <p class="mt-1 max-w-2xl text-sm leading-relaxed text-muted">{pub.description}</p>
              </div>
              <span class="ml-auto shrink-0 rounded-full border border-rule px-2 py-0.5 text-xs font-medium text-faint">
                {pub.analysts.length} {pub.analysts.length === 1 ? 'analyst' : 'analysts'}
              </span>
            </div>

            <ul class="mt-4 grid gap-2 border-t border-rule pt-4 sm:grid-cols-2">
              {pub.analysts.map((a) => (
                <li class="flex items-center gap-2.5">
                  <Avatar name={a.name} size={30} class="shrink-0" />
                  <div class="min-w-0">
                    <p class="truncate text-sm font-medium text-ink">{a.name}</p>
                    <p class="truncate text-xs text-faint">{a.focus}</p>
                  </div>
                </li>
              ))}
            </ul>

            <p class="mt-4 text-sm font-medium text-ink group-hover:text-accent">
              View &amp; discuss {pub.name} &rarr;
            </p>
          </a>
        ))
      }
    </div>

    <p class="mt-12 border-t border-rule pt-4 text-xs leading-relaxed text-faint">
      Directory compiled from
      <a href={PUBLISHERS_SOURCE.url} rel="nofollow noopener" class="text-muted underline">
        the crowdfundingsucks.com guru directory
      </a>. Listing a publisher or analyst here is not a characterization of them
      and is not investment advice. Coverage focus is as described by the source.
    </p>
  </Container>
</BaseLayout>
