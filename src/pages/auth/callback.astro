---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

/**
 * OAuth return target. Supabase (detectSessionInUrl) parses the token from the
 * URL and stores the session; we then send the user home. Add this exact URL to
 * the Supabase Auth "Redirect URLs" allowlist:
 *   https://mitchellfgibson.github.io/crowdfunding_sucks/auth/callback/
 */
---

<BaseLayout title="Signing you in…" index={false}>
  <Container class="py-24 text-center">
    <p id="cb-msg" class="text-lg text-muted">Completing sign-in…</p>
    <p id="cb-err" class="mt-3 hidden text-sm text-[var(--color-flag)]"></p>
  </Container>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { withBase } from '../../lib/url';

  const home = withBase('/');
  const errEl = document.getElementById('cb-err');

  (async () => {
    try {
      // Give detectSessionInUrl a tick to process the redirect fragment.
      const { data, error } = await supabase.auth.getSession();
      if (error) throw error;
      if (data.session) {
        window.location.replace(home);
        return;
      }
      // Fall back: listen briefly for the SIGNED_IN event.
      const timeout = setTimeout(() => {
        if (errEl) {
          errEl.textContent = 'Could not complete sign-in. Please try again.';
          errEl.classList.remove('hidden');
        }
      }, 5000);
      supabase.auth.onAuthStateChange((_e, session) => {
        if (session) {
          clearTimeout(timeout);
          window.location.replace(home);
        }
      });
    } catch (e) {
      if (errEl) {
        errEl.textContent = (e as Error).message || 'Sign-in failed.';
        errEl.classList.remove('hidden');
      }
    }
  })();
</script>
