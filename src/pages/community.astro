---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Avatar from '../components/Avatar.astro';
import ReturnFigure from '../components/ReturnFigure.astro';
import { withBase } from '../lib/url';
import { fmtRate } from '../lib/performance';
import { bareHandle } from '../lib/handle';
import { buildBoard, type BoardEntry } from '../lib/board';

/**
 * PERFORMANCE BOARD — the unified system. Merges the real publisher analysts
 * and the fictional sample accounts into one leaderboard that ranks INDIVIDUAL
 * analysts by computed track record from sourced calls.
 *
 * FIREWALL: real analysts with no sourced calls show "Unrated" — never an
 * invented score. Sample (fictional) accounts are kept in their own clearly
 * labeled group. Every figure links to the disclosed methodology.
 */
const { ranked, unrated, samples, totalAnalysts, ratedCount } = await buildBoard();

const display = (e: BoardEntry) => (e.kind === 'sample' ? bareHandle(e.name) : e.name);
---

<BaseLayout
  title="Performance Board"
  description="Analysts ranked by the computed return of their sourced recommendations."
>
  <Container class="py-10">
    <nav class="text-xs text-faint" aria-label="Breadcrumb">
      <a href={withBase('/')} class="text-muted no-underline hover:underline">Home</a>
      <span class="mx-1.5">›</span>
      <span class="text-ink">Performance Board</span>
    </nav>

    <header class="mt-3 flex flex-wrap items-end justify-between gap-4 border-b-2 border-ink pb-4">
      <div>
        <h1 class="font-serif text-3xl text-ink">Performance Board</h1>
        <p class="mt-1 max-w-2xl text-sm leading-relaxed text-muted">
          Individual analysts ranked by the computed return of their sourced
          recommendations. Open an analyst to see every dated, cited call and to
          discuss the outcomes.
        </p>
      </div>
      <dl class="flex gap-5 text-right">
        <div>
          <dt class="text-[0.68rem] font-semibold uppercase tracking-wide text-faint">Analysts</dt>
          <dd class="font-mono text-lg text-ink">{totalAnalysts}</dd>
        </div>
        <div>
          <dt class="text-[0.68rem] font-semibold uppercase tracking-wide text-faint">Rated</dt>
          <dd class="font-mono text-lg text-ink">{ratedCount}</dd>
        </div>
      </dl>
    </header>

    {/* honest cold-start note when no real analyst is rated yet */}
    {
      ratedCount === 0 && (
        <div
          role="note"
          class="mt-6 rounded-md border border-rule bg-paper-raised px-4 py-3 text-sm leading-relaxed text-muted"
        >
          <strong class="text-ink">No real analyst is rated yet.</strong> A score
          appears only once an analyst has a sourced recommendation on file — we
          don’t invent calls for real people. The sample accounts below show how a
          scored profile renders.
          <a href={withBase('/methodology/')} class="text-accent underline">How scoring works →</a>
        </div>
      )
    }

    {/* RANKED — real analysts with a computed score */}
    {
      ranked.length > 0 && (
        <section class="mt-8">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-faint">Ranked · by avg. computed return</h2>
          <div class="mt-3 flex flex-col gap-2">
            {ranked.map((e, i) => (
              <a
                href={withBase(`/community/${e.slug}/`)}
                class="group flex items-center gap-4 rounded-xl border border-rule border-l-4 border-l-accent bg-paper-raised py-3 pl-4 pr-4 no-underline shadow-sm transition-all hover:-translate-y-0.5 hover:border-accent hover:bg-accent/5"
              >
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent/10 font-mono text-xs font-semibold text-accent group-hover:bg-accent group-hover:text-white">{i + 1}</span>
                <Avatar name={e.name} size={40} />
                <div class="min-w-0 flex-1">
                  <p class="truncate font-semibold text-ink group-hover:text-accent">{display(e)}</p>
                  <p class="truncate text-xs text-faint">{e.publisher}{e.focus && <span> · {e.focus}</span>}</p>
                </div>
                <div class="hidden shrink-0 items-center gap-5 text-center sm:flex">
                  <div class="w-16"><p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Avg</p><ReturnFigure ratio={e.perf.avgReturn} class="text-sm" /></div>
                  <div class="w-12"><p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Win</p><p class="font-mono text-sm tabular-nums text-muted">{fmtRate(e.perf.winRate)}</p></div>
                  <div class="w-10"><p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Calls</p><p class="font-mono text-sm tabular-nums text-muted">{e.perf.total}</p></div>
                </div>
                <span class="shrink-0 text-faint transition-transform group-hover:translate-x-0.5 group-hover:text-accent" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {/* UNRATED — real analysts with no sourced calls yet */}
    {
      unrated.length > 0 && (
        <section class="mt-10">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-faint">
            Unrated · no tracked calls yet ({unrated.length})
          </h2>
          <div class="mt-3 grid gap-2 sm:grid-cols-2">
            {unrated.map((e) => (
              <a
                href={withBase(`/community/${e.slug}/`)}
                class="group flex items-center gap-3 rounded-lg border border-rule bg-paper-raised p-3 no-underline transition-colors hover:border-accent/40 hover:bg-accent/5"
              >
                <Avatar name={e.name} size={34} class="shrink-0" />
                <div class="min-w-0 flex-1">
                  <p class="truncate text-sm font-medium text-ink group-hover:text-accent">{e.name}</p>
                  <p class="truncate text-xs text-faint">{e.publisher}{e.focus && <span> · {e.focus}</span>}</p>
                </div>
                <span class="shrink-0 rounded-full border border-rule px-2 py-0.5 text-[0.6rem] font-medium text-faint">Unrated</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {/* SAMPLES — fictional demo accounts, clearly separated */}
    {
      samples.length > 0 && (
        <section class="mt-10">
          <div class="flex items-center gap-2">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-faint">Sample accounts</h2>
            <span class="rounded-full border border-[var(--color-notice)]/50 px-1.5 py-0.5 text-[0.6rem] font-medium text-[var(--color-notice)]">demo</span>
          </div>
          <p class="mt-1 text-xs text-faint">Fictional accounts with placeholder figures — shown to demonstrate how a scored profile renders. Not real people.</p>
          <div class="mt-3 flex flex-col gap-2">
            {samples.map((e) => (
              <a
                href={withBase(`/community/${e.slug}/`)}
                class="group flex items-center gap-4 rounded-xl border border-dashed border-rule bg-paper-raised py-3 pl-4 pr-4 no-underline transition-colors hover:border-accent/40 hover:bg-accent/5"
              >
                <Avatar name={e.name} size={38} />
                <div class="min-w-0 flex-1">
                  <p class="truncate font-semibold text-ink group-hover:text-accent">{display(e)}</p>
                  <p class="truncate text-xs text-faint">illustrative sample</p>
                </div>
                <div class="hidden shrink-0 items-center gap-5 text-center sm:flex">
                  <div class="w-16"><p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Avg</p><ReturnFigure ratio={e.perf.avgReturn} class="text-sm" /></div>
                  <div class="w-12"><p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Win</p><p class="font-mono text-sm tabular-nums text-muted">{fmtRate(e.perf.winRate)}</p></div>
                  <div class="w-10"><p class="text-[0.6rem] font-semibold uppercase tracking-wide text-faint">Calls</p><p class="font-mono text-sm tabular-nums text-muted">{e.perf.total}</p></div>
                </div>
                <span class="shrink-0 text-faint transition-transform group-hover:translate-x-0.5 group-hover:text-accent" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <p class="mt-12 border-t border-rule pt-4 text-xs leading-relaxed text-faint">
      Returns are computed from cited entry/current valuations; an analyst with no
      sourced calls shows “Unrated.” See the
      <a href={withBase('/methodology/')} class="text-muted underline">methodology</a>.
      Factual and computed — not investment advice. Profiled parties may use the
      <a href={withBase('/right-of-reply/')} class="text-muted underline">right of reply</a>.
    </p>
  </Container>
</BaseLayout>
