---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Avatar from '../components/Avatar.astro';
import ReturnFigure from '../components/ReturnFigure.astro';
import { withBase } from '../lib/url';
import { summarize, fmtRate } from '../lib/performance';
import { bareHandle } from '../lib/handle';

/**
 * COMMUNITY — PERFORMANCE BOARD (theRX-style forum index)
 *
 * A classic message-board index: a board header with aggregate stats, then a
 * table of "threads" — one per tracked outlet account — sortable by sourced
 * track record. Each row links into that account's thread (its dated, cited
 * recommendations + discussion).
 *
 * Firewall: every figure is build-time arithmetic over sourced frontmatter
 * (src/lib/performance.ts). Seeded accounts are CLEARLY-FICTIONAL illustrations
 * (draft:true, example.com sources) behind a banner; real accounts render
 * through the same path.
 */

const outlets = (await getCollection('gurus')).map((g) => ({
  entry: g,
  perf: summarize(g.data.recommendations),
  slug: g.data.slug ?? g.id,
}));

const allIllustrative = outlets.length > 0 && outlets.every((o) => o.entry.data.draft);

// Board ranked by avg computed return; accounts with no scored picks sink.
const ranked = [...outlets].sort(
  (a, b) => (b.perf.avgReturn ?? -Infinity) - (a.perf.avgReturn ?? -Infinity),
);

// Board-level aggregates.
const totalPicks = outlets.reduce((n, o) => n + o.perf.total, 0);
const totalResolved = outlets.reduce((n, o) => n + o.perf.resolved, 0);
const lastActivity = outlets
  .map((o) => o.perf.lastDate)
  .filter((d): d is Date => d instanceof Date)
  .sort((a, b) => b.getTime() - a.getTime())[0];

const fmtDay = (d: Date | null) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—';
---

<BaseLayout
  title="Performance Board"
  description="A message board of tracked accounts ranked by sourced recommendation performance."
>
  <Container class="py-10">
    {/* breadcrumb */}
    <nav class="text-xs text-faint" aria-label="Breadcrumb">
      <a href={withBase('/')} class="text-muted no-underline hover:underline">Home</a>
      <span class="mx-1.5">›</span>
      <span class="text-ink">Performance Board</span>
    </nav>

    {/* board header */}
    <header class="mt-3 flex flex-wrap items-end justify-between gap-4 border-b-2 border-ink pb-4">
      <div>
        <h1 class="font-serif text-3xl text-ink">Performance Board</h1>
        <p class="mt-1 max-w-2xl text-sm leading-relaxed text-muted">
          Tracked accounts, ranked by the computed return of their sourced
          recommendations. Open a thread to see every dated, cited call and to
          discuss how it played out.
        </p>
      </div>
      <dl class="flex gap-5 text-right">
        <div>
          <dt class="text-[0.68rem] font-semibold uppercase tracking-wide text-faint">Accounts</dt>
          <dd class="font-mono text-lg text-ink">{outlets.length}</dd>
        </div>
        <div>
          <dt class="text-[0.68rem] font-semibold uppercase tracking-wide text-faint">Calls</dt>
          <dd class="font-mono text-lg text-ink">{totalPicks}</dd>
        </div>
        <div>
          <dt class="text-[0.68rem] font-semibold uppercase tracking-wide text-faint">Resolved</dt>
          <dd class="font-mono text-lg text-ink">{totalResolved}</dd>
        </div>
      </dl>
    </header>

    {
      allIllustrative && (
        <div
          role="note"
          class="mt-4 rounded-md border border-[var(--color-notice)]/40 bg-[var(--color-notice)]/10 px-4 py-3 text-sm leading-relaxed text-[var(--color-notice)]"
        >
          <strong>Illustrative preview.</strong> These accounts are fictional
          samples (placeholder figures, <code class="font-mono">example.com</code>
          sources) shown only to demonstrate the board. No real person is being
          scored. Real, sourced accounts render through this same screen.
        </div>
      )
    }

    {/* board table — forum index of threads */}
    <div class="mt-6 overflow-hidden rounded-lg border border-rule">
      {/* column header */}
      <div
        class="hidden grid-cols-[1fr_90px_70px_60px_120px] gap-3 border-b border-rule bg-paper-raised px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-wide text-faint sm:grid"
      >
        <span>Account / thread</span>
        <span class="text-right">Avg return</span>
        <span class="text-right">Win</span>
        <span class="text-right">Calls</span>
        <span class="text-right">Last call</span>
      </div>

      {
        ranked.map((o, i) => (
          <a
            href={withBase(`/community/${o.slug}/`)}
            class="grid grid-cols-[1fr_auto] items-center gap-3 border-t border-rule px-4 py-3 no-underline transition-colors first:border-t-0 hover:bg-paper-raised sm:grid-cols-[1fr_90px_70px_60px_120px]"
          >
            {/* account cell */}
            <div class="flex items-center gap-3">
              <span class="hidden w-5 text-right font-mono text-sm text-faint sm:inline">{i + 1}</span>
              <Avatar name={o.entry.data.name} size={38} />
              <div class="min-w-0">
                <p class="truncate font-semibold text-ink">{bareHandle(o.entry.data.name)}</p>
                <p class="truncate text-xs text-faint">{o.entry.data.summary.split('.')[0]}.</p>
              </div>
              {o.entry.data.draft && (
                <span class="ml-auto hidden shrink-0 rounded-full border border-[var(--color-notice)]/50 px-2 py-0.5 text-[0.65rem] font-medium text-[var(--color-notice)] sm:inline">
                  sample
                </span>
              )}
            </div>

            {/* mobile: compact stat line */}
            <div class="text-right sm:hidden">
              <ReturnFigure ratio={o.perf.avgReturn} class="text-sm" />
              <p class="text-xs text-faint">{o.perf.total} calls</p>
            </div>

            {/* desktop stat columns */}
            <span class="hidden text-right sm:block"><ReturnFigure ratio={o.perf.avgReturn} class="text-sm" /></span>
            <span class="hidden text-right font-mono text-sm tabular-nums text-muted sm:block">{fmtRate(o.perf.winRate)}</span>
            <span class="hidden text-right font-mono text-sm tabular-nums text-muted sm:block">{o.perf.total}</span>
            <span class="hidden text-right text-xs text-faint sm:block">{fmtDay(o.perf.lastDate)}</span>
          </a>
        ))
      }

      {
        outlets.length === 0 && (
          <p class="px-4 py-8 text-sm text-muted">
            No accounts yet. Add sourced profiles to the <code>gurus</code> collection
            and they appear here automatically.
          </p>
        )
      }
    </div>

    <p class="mt-4 text-xs text-faint">
      Last activity {fmtDay(lastActivity)}. Returns are computed from cited
      entry/current valuations; a call with no sourced figures shows “—”.
      <a href={withBase('/methodology/')} class="text-muted underline">Methodology</a>.
    </p>
  </Container>
</BaseLayout>
