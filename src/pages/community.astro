---
import { withBase } from '../lib/url';

/**
 * The performance board now lives at /gurus (merged with the publisher
 * directory). This index just redirects there. Individual analyst profiles
 * still live at /community/[outlet]/ and are linked from /gurus.
 */
const dest = withBase('/gurus/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <link rel="canonical" href={dest} />
    <meta name="robots" content="noindex" />
    <title>Performance board moved</title>
  </head>
  <body>
    <p>The performance board has moved to <a href={dest}>Publishers &amp; Performance</a>.</p>
    <script is:inline set:html={`location.replace(${JSON.stringify(dest)});`} />
  </body>
</html>
