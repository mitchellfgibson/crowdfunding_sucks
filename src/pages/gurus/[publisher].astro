---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Avatar from '../../components/Avatar.astro';
import PortalLogo from '../../components/PortalLogo.astro';
import ChatLog from '../../components/ChatLog.astro';
import { withBase } from '../../lib/url';
import { publishers, publisherSlug, PUBLISHERS_SOURCE } from '../../data/publishers';
import { publisherChat } from '../../lib/sampleChat';

/**
 * Publisher detail page: the publisher's analysts (sourced facts only) plus an
 * open community discussion rendered as an ILLUSTRATIVE sample chat (fictional
 * accounts — no real users, no backend yet). No track records or scoring.
 */
export const getStaticPaths = (async () => {
  return publishers.map((pub) => ({
    params: { publisher: publisherSlug(pub.name) },
    props: { pub },
  }));
}) satisfies GetStaticPaths;

const { pub } = Astro.props;
const slug = publisherSlug(pub.name);
const messages = publisherChat(`publisher/${slug}`, pub.name);
---

<BaseLayout title={`${pub.name} — Publishers & Gurus`} description={pub.description}>
  <Container class="py-10">
    <nav class="text-xs text-faint" aria-label="Breadcrumb">
      <a href={withBase('/')} class="text-muted no-underline hover:underline">Home</a>
      <span class="mx-1.5">›</span>
      <a href={withBase('/gurus/')} class="text-muted no-underline hover:underline">Publishers &amp; Gurus</a>
      <span class="mx-1.5">›</span>
      <span class="text-ink">{pub.name}</span>
    </nav>

    <header class="mt-3 flex items-start gap-4 border-b-2 border-ink pb-5">
      <PortalLogo name={pub.name} url={pub.url} logo={pub.logo} size={56} />
      <div class="min-w-0">
        <h1 class="font-serif text-3xl text-ink">{pub.name}</h1>
        <p class="mt-1 max-w-2xl text-sm leading-relaxed text-muted">{pub.description}</p>
        <p class="mt-1.5 text-xs text-faint">
          {pub.analysts.length} {pub.analysts.length === 1 ? 'analyst' : 'analysts'} tracked
        </p>
      </div>
    </header>

    {/* analysts */}
    <section class="mt-6">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-faint">Analysts</h2>
      <ul class="mt-3 grid gap-2 sm:grid-cols-2">
        {
          pub.analysts.map((a) => (
            <li class="flex items-center gap-2.5 rounded-lg border border-rule bg-paper-raised p-3">
              <Avatar name={a.name} size={34} class="shrink-0" />
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-ink">{a.name}</p>
                <p class="truncate text-xs text-faint">{a.focus}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    {/* editorial / community boundary */}
    <div class="mt-10">
      <div class="flex items-center gap-3">
        <span class="h-px flex-1 bg-rule"></span>
        <span class="text-center text-xs font-semibold uppercase tracking-wide text-faint">
          Below: community discussion — not editorial content
        </span>
        <span class="h-px flex-1 bg-rule"></span>
      </div>
      <h2 class="mt-4 font-serif text-xl text-ink">Open discussion</h2>
      <p class="mt-1 text-sm text-muted">What investors are saying about {pub.name}.</p>
      <div class="mt-4">
        <ChatLog seed={`publisher/${slug}`} messages={messages} label="Open discussion" open={true} />
      </div>
    </div>

    <p class="mt-10 border-t border-rule pt-4 text-xs leading-relaxed text-faint">
      Analyst list compiled from
      <a href={PUBLISHERS_SOURCE.url} rel="nofollow noopener" class="text-muted underline">
        the crowdfundingsucks.com guru directory
      </a>. Reference only — not a characterization and not investment advice.
      <a href={withBase('/gurus/')} class="text-muted underline">← All publishers</a>
    </p>
  </Container>
</BaseLayout>
