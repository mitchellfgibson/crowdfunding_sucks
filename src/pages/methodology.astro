---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import { withBase } from '../lib/url';

/**
 * Methodology — the disclosed formula every computed score links back to. This
 * is the firewall's transparency requirement made concrete (CLAUDE.md rules
 * 1–4): scores are arithmetic over cited facts, outcomes are enums, uncited
 * data does not render. Nothing here is fabricated; it describes the actual
 * computation in src/lib/performance.ts.
 */
const outcomes = [
  ['active', 'Still operating / the position is open. Not yet a final result.'],
  ['acquired', 'Bought by another company — a verifiable terminal event.'],
  ['delisted', 'Removed from a market or platform.'],
  ['dissolved', 'Wound down or ceased to exist.'],
  ['litigation_public_record', 'Subject of litigation documented in the public record.'],
  ['unknown', 'No verifiable outcome on file. Honest and safe — contributes no claim.'],
];
---

<BaseLayout
  title="Methodology"
  description="How track records on this site are computed: arithmetic over cited facts, with a disclosed formula."
>
  <Container width="prose" class="py-12">
    <p class="text-sm font-semibold uppercase tracking-wide text-accent">Methodology</p>
    <h1 class="mt-2 font-serif text-3xl text-ink sm:text-4xl">How track records are computed</h1>

    <p class="mt-6 text-lg leading-relaxed text-muted">
      Every number on this site is arithmetic over publicly cited facts — never
      an opinion, never hand-authored. This page is the disclosed formula that
      each score links back to. If a claim cannot be tied to a source, it does
      not appear.
    </p>

    <h2 class="mt-12 font-serif text-2xl text-ink">The core rules</h2>
    <ol class="mt-4 space-y-3 text-ink">
      <li class="flex gap-3">
        <span class="font-mono text-accent">1.</span>
        <span><strong class="font-semibold">Cited facts only.</strong> A recommendation must carry at least one source. An uncited call is rejected before it can affect any score.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-mono text-accent">2.</span>
        <span><strong class="font-semibold">Computed, never authored.</strong> Returns and win rates are calculated at build time from the entry and current valuations recorded in a sourced recommendation. No score is typed by hand.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-mono text-accent">3.</span>
        <span><strong class="font-semibold">Outcomes are a fixed enum.</strong> Results are limited to the verifiable events below — no free-text characterizations, no opinion verbs.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-mono text-accent">4.</span>
        <span><strong class="font-semibold">Editorial vs. discussion.</strong> The computed, cited facts are the editorial layer. Opinion lives only in the community discussion beneath each profile, clearly separated.</span>
      </li>
    </ol>

    <h2 class="mt-12 font-serif text-2xl text-ink">How a return is calculated</h2>
    <p class="mt-3 leading-relaxed text-muted">
      For a single recommendation, the return is the change between the valuation
      at the time of the call and the current (or final) valuation — both taken
      from cited sources:
    </p>
    <pre class="mt-4 overflow-x-auto rounded-lg border border-rule bg-paper-raised p-4 font-mono text-sm text-ink">return = (current valuation ÷ entry valuation) − 1</pre>
    <p class="mt-3 leading-relaxed text-muted">
      A recommendation contributes a return <strong>only</strong> when both
      valuations are present in its sources. If either is missing, the call still
      appears on the profile, but it is counted as <em>unscored</em> — it never
      becomes a silent zero.
    </p>

    <h2 class="mt-12 font-serif text-2xl text-ink">Account-level figures</h2>
    <ul class="mt-4 space-y-2 text-muted">
      <li><strong class="text-ink">Average return</strong> — the mean of the per-call returns that could be computed (the <em>scored</em> calls only).</li>
      <li><strong class="text-ink">Win rate</strong> — the share of scored calls with a positive return.</li>
      <li><strong class="text-ink">Median / best / worst</strong> — order statistics over the same scored set.</li>
      <li><strong class="text-ink">Resolved</strong> — how many calls reached a terminal outcome (acquired, delisted, dissolved, or litigation-on-record), versus those still active or unknown.</li>
    </ul>
    <p class="mt-3 leading-relaxed text-muted">
      An account with <strong>no sourced calls</strong> shows no score — it is
      marked <strong>“Unrated.”</strong> We would rather show nothing than imply a
      track record we cannot cite.
    </p>

    <h2 class="mt-12 font-serif text-2xl text-ink">Outcome definitions</h2>
    <dl class="mt-4 divide-y divide-rule overflow-hidden rounded-lg border border-rule">
      {
        outcomes.map(([k, v]) => (
          <div class="grid grid-cols-1 gap-1 px-4 py-3 sm:grid-cols-[200px_1fr]">
            <dt class="font-mono text-sm text-ink">{k}</dt>
            <dd class="text-sm leading-relaxed text-muted">{v}</dd>
          </div>
        ))
      }
    </dl>

    <h2 class="mt-12 font-serif text-2xl text-ink">Samples vs. real data</h2>
    <p class="mt-3 leading-relaxed text-muted">
      Some accounts on the board are clearly-labeled <strong>illustrative
      samples</strong> (fictional, with placeholder figures) used to demonstrate
      how a scored profile looks. They are always marked as samples and are never
      mixed with real, sourced track records. Real accounts show a score only once
      sourced calls exist for them.
    </p>

    <p class="mt-12 rounded-lg border border-rule bg-paper-raised p-4 text-sm leading-relaxed text-muted">
      This is a factual, computed accountability tool — not investment advice and
      not a characterization of any person or company. Anyone profiled may use the
      <a href={withBase('/right-of-reply/')} class="text-accent underline">right-of-reply</a>
      process to respond or correct the record.
    </p>
  </Container>
</BaseLayout>
