---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import GoogleSignIn from '../components/GoogleSignIn.astro';
import { withBase } from '../lib/url';

// Lead-gen front door (BUILD_PLAN Phase 0/1 priority): newsletter capture first.
const tracks = [
  'Winners',
  'Losers',
  'Hot Deals',
  'Cap Tables',
  'Publisher Picks',
  'Deal Structures',
];

const following = [
  'crowdfunding activity',
  'public market opportunities',
  'publisher picks',
  'cap table breakdowns',
  'weekly insights',
];

// Why crowdfunding fell short — framing adapted from crowdfundingsucks.com/about.
const failures = [
  'Misaligned incentives',
  'Overvalued deals',
  'Lack of transparency',
  'No real accountability',
  'No investor community',
];
---

<BaseLayout title="CrowdfundingSucks">
  <section class="border-b border-rule">
    <Container class="py-20 text-center sm:py-28">
      <h1 class="mx-auto max-w-3xl text-3xl font-medium text-muted sm:text-4xl">
        Crowdfunding was supposed to level the playing field.
      </h1>
      <p
        class="mx-auto mt-4 max-w-3xl font-serif text-xl font-bold italic leading-tight tracking-tight text-ink sm:text-2xl"
      >
        We think investors deserve better.
      </p>

      <p class="mt-12 text-sm font-semibold uppercase tracking-wide text-faint">Track</p>
      <ul class="mx-auto mt-3 grid max-w-xl grid-cols-1 gap-x-6 gap-y-2 text-left sm:grid-cols-2">
        {
          tracks.map((t) => (
            <li class="flex items-center gap-2 text-lg text-ink">
              <span class="text-[var(--color-gain)]" aria-hidden="true">✔</span>
              {t}
            </li>
          ))
        }
      </ul>

      <div class="mt-12 flex justify-center">
        <GoogleSignIn label="Join with Google" />
      </div>
    </Container>
  </section>

  {/* why this exists — framing from crowdfundingsucks.com/about */}
  <section class="border-b border-rule bg-paper-raised">
    <Container class="py-16 sm:py-20">
      <p class="max-w-2xl text-xl leading-relaxed text-muted">
        Retail investors are rarely getting in on the ground floor — they’re
        often entering on the <span class="font-medium text-ink">12th floor</span>.
        Access doesn’t always mean opportunity.
      </p>

      <h2 class="mt-12 font-serif text-2xl text-ink sm:text-3xl">
        Crowdfunding didn’t fail because of the idea.
      </h2>
      <p class="mt-2 text-muted">It failed because of:</p>
      <ul class="mt-4 grid max-w-xl gap-2 sm:grid-cols-2">
        {
          failures.map((f) => (
            <li class="flex items-center gap-2 text-ink">
              <span class="text-[var(--color-flag)]" aria-hidden="true">✕</span>
              {f}
            </li>
          ))
        }
      </ul>

      <p class="mt-12 max-w-2xl font-serif text-2xl italic text-ink sm:text-3xl">
        We’re not just exposing what’s broken. We’re building what should exist.
      </p>
      <p class="mt-4 max-w-2xl leading-relaxed text-muted">
        A community where opportunities are evaluated collectively, transparency
        is the standard, and experienced and everyday investors operate with
        better alignment.
      </p>
    </Container>
  </section>

  <Container class="py-14">
    <p class="text-sm font-medium text-muted">Join thousands of investors following:</p>
    <ul class="mt-3 flex flex-wrap gap-x-2 gap-y-2 text-sm text-faint">
      {
        following.map((f, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && <span class="text-rule" aria-hidden="true">•</span>}
            <span>{f}</span>
          </li>
        ))
      }
    </ul>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href={withBase('/portals/')}
        class="rounded-md border border-rule px-4 py-2 text-sm font-medium text-ink no-underline transition-colors hover:bg-paper-raised"
      >
        Browse 25 platforms
      </a>
      <a
        href={withBase('/community/')}
        class="rounded-md border border-rule px-4 py-2 text-sm font-medium text-ink no-underline transition-colors hover:bg-paper-raised"
      >
        Performance board
      </a>
      <a
        href={withBase('/lessons/')}
        class="rounded-md border border-rule px-4 py-2 text-sm font-medium text-ink no-underline transition-colors hover:bg-paper-raised"
      >
        Lessons
      </a>
    </div>

    <p class="mt-10 max-w-2xl text-xs leading-relaxed text-faint">
      Not investment advice. Track records are computed from publicly cited facts
      via a <a href={withBase('/methodology/')} class="text-muted underline">disclosed methodology</a>;
      a claim with no source does not render.
    </p>
  </Container>
</BaseLayout>
