---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import AuthCTA from '../components/AuthCTA.astro';
import StatCounter from '../components/StatCounter.astro';
import MarketShareChart from '../components/MarketShareChart.astro';
import CapitalChart from '../components/CapitalChart.astro';
import { withBase } from '../lib/url';
import { publishers } from '../data/publishers';
import { problemStats, marketStats, communityGoals, INDUSTRY_SOURCE } from '../data/industry';

// Lead-gen front door. Stats are REAL counts of what's on this site (rule 1:
// no fabricated/unsourced numbers) — they update as content is added.
const portals = (await getCollection('portals')).filter((p) => !p.data.draft);
const analystCount = publishers.reduce((n, p) => n + p.analysts.length, 0);

const stats = [
  { value: `${portals.length}`, label: 'Platforms tracked' },
  { value: `${publishers.length}`, label: 'Publishers covered' },
  { value: `${analystCount}`, label: 'Analysts followed' },
  { value: 'Sourced', label: 'Every datum cited' },
];

const tracks = ['Winners', 'Losers', 'Hot Deals', 'Cap Tables', 'Publisher Picks', 'Deal Structures'];

// Four pillars — what the platform does (factual about our own product).
const pillars = [
  {
    title: 'Track the platforms',
    body: 'Every major crowdfunding portal — Wefunder, StartEngine, Republic and more — with regulation type, asset focus, and operating status.',
    href: withBase('/portals/'),
    cta: 'Browse platforms',
  },
  {
    title: 'Follow the publishers',
    body: 'The newsletter writers and influencers shaping the crowdfunding ecosystem — know who is promoting what, and what they cover.',
    href: withBase('/gurus/'),
    cta: 'See publishers',
  },
  {
    title: 'Join the discussion',
    body: 'Investors talk through deals and outcomes in the open — insights and red flags surfaced before you commit capital.',
    href: withBase('/community/'),
    cta: 'Performance board',
  },
  {
    title: 'Learn the mechanics',
    body: 'Plain-English lessons on cap tables, dilution, evaluating a Reg CF/A raise, and reading a Form C.',
    href: withBase('/lessons/'),
    cta: 'Read the lessons',
  },
];

---

<BaseLayout title="CrowdfundingSucks">
  {/* hero */}
  <section class="border-b border-rule">
    <Container class="py-20 text-center sm:py-28">
      <h1 class="mx-auto max-w-3xl text-3xl font-medium text-muted sm:text-4xl">
        Crowdfunding was supposed to level the playing field.
      </h1>
      <p class="mx-auto mt-4 max-w-3xl font-serif text-xl font-bold italic leading-tight tracking-tight text-ink sm:text-2xl">
        We think investors deserve better.
      </p>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted">
        We track the top crowdfunding platforms, monitor the newsletter gurus,
        and bring investors together — with sourced facts, not hype.
      </p>

      <ul class="mx-auto mt-10 grid max-w-xl grid-cols-1 gap-x-6 gap-y-2 text-left sm:grid-cols-2">
        {
          tracks.map((t) => (
            <li class="flex items-center gap-2 text-lg text-ink">
              <span class="text-[var(--color-gain)]" aria-hidden="true">✔</span>
              {t}
            </li>
          ))
        }
      </ul>

      <div class="mt-12 flex justify-center">
        <AuthCTA label="Join with Google" />
      </div>
    </Container>
  </section>

  {/* real stats bar */}
  <section class="border-b border-rule bg-paper-raised">
    <Container class="py-10">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        {
          stats.map((s) => (
            <div>
              <p class="font-mono text-3xl font-semibold text-ink">{s.value}</p>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-faint">{s.label}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  {/* four pillars */}
  <Container class="py-16">
    <h2 class="font-serif text-2xl text-ink sm:text-3xl">Your command center for crowdfunding intelligence</h2>
    <p class="mt-2 max-w-2xl text-muted">Four ways the community keeps investors informed.</p>
    <div class="mt-8 grid gap-3 sm:grid-cols-2">
      {
        pillars.map((p) => (
          <a
            href={p.href}
            class="group flex flex-col rounded-xl border border-rule bg-paper-raised p-5 no-underline shadow-sm transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:bg-accent/5 hover:shadow-md"
          >
            <h3 class="font-serif text-xl text-ink group-hover:text-accent">{p.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{p.body}</p>
            <span class="mt-4 text-sm font-medium text-ink group-hover:text-accent">{p.cta} &rarr;</span>
          </a>
        ))
      }
    </div>
  </Container>

  {/* the transparency problem — animated stat counters */}
  <section class="border-y border-rule bg-paper-raised">
    <Container class="py-16 sm:py-20">
      <h2 class="font-serif text-2xl text-ink sm:text-3xl">The crowdfunding industry has a transparency problem</h2>
      <p class="mt-2 max-w-2xl text-muted">
        Billions have flowed through equity crowdfunding since Reg CF launched in
        2016 — yet investors are largely left in the dark about outcomes.
      </p>
      <div class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-3">
        {problemStats.map((s) => <StatCounter stat={s} />)}
      </div>
      <p class="mt-10 text-xs leading-relaxed text-faint">
        Figures as published by
        <a href={INDUSTRY_SOURCE.url} rel="nofollow noopener" class="text-muted underline">{INDUSTRY_SOURCE.label}</a>.
        <a href={withBase('/about/')} class="text-muted underline">Why this exists →</a>
      </p>
    </Container>
  </section>

  {/* crowdfunding by the numbers — market data + charts */}
  <Container class="py-16 sm:py-20">
    <h2 class="font-serif text-2xl text-ink sm:text-3xl">Crowdfunding by the numbers</h2>
    <p class="mt-2 max-w-2xl text-muted">
      The market is growing fast — but transparency hasn’t kept pace.
    </p>

    <div class="mt-8 grid grid-cols-2 gap-x-6 gap-y-10 lg:grid-cols-4">
      {marketStats.map((s) => <StatCounter stat={s} size="md" />)}
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-rule bg-paper-raised p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-faint">Platform market share</h3>
        <div class="mt-4"><MarketShareChart /></div>
      </div>
      <div class="rounded-xl border border-rule bg-paper-raised p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-faint">Annual Reg CF capital raised</h3>
        <div class="mt-4"><CapitalChart /></div>
      </div>
    </div>

    <p class="mt-6 text-xs leading-relaxed text-faint">
      Market figures and breakdowns as published by
      <a href={INDUSTRY_SOURCE.url} rel="nofollow noopener" class="text-muted underline">{INDUSTRY_SOURCE.label}</a>;
      shown for context, not as investment advice.
    </p>
  </Container>

  {/* closing CTA */}
  <Container class="py-16">
    <div class="rounded-2xl border border-rule bg-paper-raised p-8 text-center">
      <h2 class="font-serif text-2xl text-ink sm:text-3xl">Be part of the investor community</h2>
      <p class="mx-auto mt-2 max-w-xl text-muted">
        An investor-first community changing how crowdfunding gets evaluated —
        collectively, transparently, on the record.
      </p>

      {/* what the community is building toward (goals, not current counts) */}
      <p class="mt-8 text-xs font-semibold uppercase tracking-wide text-faint">The community we’re building</p>
      <div class="mx-auto mt-3 grid max-w-xl grid-cols-3 gap-4">
        {communityGoals.map((s) => <StatCounter stat={s} size="md" />)}
      </div>

      <div class="mt-8 flex justify-center">
        <AuthCTA label="Join with Google" />
      </div>
    </div>

    <p class="mx-auto mt-10 max-w-2xl text-center text-xs leading-relaxed text-faint">
      Not investment advice. Track records are computed from publicly cited facts
      via a <a href={withBase('/methodology/')} class="text-muted underline">disclosed methodology</a>;
      a claim with no source does not render.
    </p>
  </Container>
</BaseLayout>
