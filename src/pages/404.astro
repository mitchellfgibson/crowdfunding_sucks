---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import { withBase } from '../lib/url';
---

<BaseLayout title="Page not found" index={false}>
  <Container class="py-24 sm:py-32">
    <p class="text-sm font-semibold uppercase tracking-wide text-accent">404</p>
    <h1 class="mt-3 text-3xl font-semibold text-ink sm:text-4xl">Page not found</h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">
      That page doesn’t exist (yet). Much of the site is still being built.
    </p>
    <p class="mt-10">
      <a href={withBase('/')} class="text-sm font-medium text-ink underline">&larr; Back home</a>
    </p>
  </Container>
</BaseLayout>
